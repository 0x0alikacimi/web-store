{
    "compilerOptions": {
      "target": "ES2022",
      "module": "CommonJS",
      "rootDir": "./src",
      "outDir": "./dist",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,

      // ADD THIS: Tell TS where to find our custom definitions
      "typeRoots": ["./node_modules/@types", "./src/types"]
    },

    // ADD THIS: This is the magic fix for ts-node
    "ts-node": {
      "files": true
    },

    "include": ["src/**/*"]
}
